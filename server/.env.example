# Phase 1
PORT=3000
REDIS_URL=redis://localhost:6379/0
API_KEY_PREFIX=snp_
DEFAULT_TTL_SECONDS=604800
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# Phase 2 — Postgres
DATABASE_URL=postgres://checkpoint:checkpoint_dev@localhost:5432/snapstate

# Phase 2 — Admin
ADMIN_SECRET=admin_dev_secret_change_me

# Phase 2 — Cloudflare R2 (S3-compatible)
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_access_key
R2_SECRET_ACCESS_KEY=your_secret_key
R2_BUCKET_NAME=checkpoint-archives
R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com

# Phase 2 — Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_CHECKPOINT_WRITE=price_...
STRIPE_PRICE_STORAGE_GB=price_...
STRIPE_PRICE_RESUME=price_...
STRIPE_PRICE_REPLAY=price_...

# MCP Server (used by mcp-server package)
SNAPSTATE_API_URL=http://localhost:3000
SNAPSTATE_API_KEY=snp_your_key_here

# Phase 3 — Auth
JWT_SECRET=dev_jwt_secret_change_in_production_minimum_32_chars
APP_URL=http://localhost:3000
MAX_API_KEYS_PER_ACCOUNT=10
MAX_AGENTS_PER_ACCOUNT=50

# Email (Mailpit for dev — http://localhost:8025)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@snapstate.dev
